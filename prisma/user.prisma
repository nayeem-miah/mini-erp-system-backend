model User {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  password       String?
  email          String     @unique
  role           UserRole   @default(EMPLOYEE)
  status         UserStatus @default(ACTIVE)
  Phone          String?
  profilePicture String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  sales          Sale[]

  @@map("users")
}
